# ============================================================
#  LaptopRent (.env.example)
#  Salin file ini menjadi .env, lalu isi semua nilai di bawah.
#  JANGAN commit file .env ke Git!
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── DATABASE MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=laptoprent

# ── JWT ──────────────────────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_random_string_minimal_64_karakter
JWT_EXPIRES_IN=7d

# ── MIDTRANS SANDBOX ─────────────────────────────────────────
# Daftar di: https://dashboard.sandbox.midtrans.com
# Settings → Access Keys → Sandbox
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── UPLOAD ──────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
